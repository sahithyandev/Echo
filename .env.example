# Required in production (fails fast on boot if unset). Generate with:
#   openssl rand -hex 32
ECHO_JWT_SECRET=

# development | production
NODE_ENV=development

# SQLite file. Default: ~/.echo/echo.db in production, repo-root echo.db in dev.
# ECHO_DATABASE_URL=file:/data/echo.db

# Data dir (album art, etc). Default: ~/.echo in dev, /data in Docker.
# ECHO_DATA_DIR=/data

# Music library root. Default: ~/Music in dev, /music in Docker.
# ECHO_MUSIC_DIR=/music

# Default: 3000
# ECHO_PORT=3000

# Default: localhost. Docker Compose sets 0.0.0.0.
# ECHO_HOST=0.0.0.0
